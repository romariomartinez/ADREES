{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/static/index.html"
    },
    {
      "source": "/firebase-messaging-sw.js",
      "destination": "/static/firebase-messaging-sw.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    }
  ]
}
